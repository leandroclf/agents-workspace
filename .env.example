# ── Autenticação (escolha UM dos dois métodos) ────────────────────────────────
#
# Método 1: OAuth com assinatura claude.ai (recomendado — sem custo por API key)
#   1. Acesse https://console.anthropic.com/settings/oauth-apps
#   2. Crie um OAuth App com redirect_uri: http://localhost:54545/oauth/callback
#   3. Cole o client_id abaixo e rode: python3 authenticate.py
ANTHROPIC_CLIENT_ID=...
ANTHROPIC_CLIENT_SECRET=...   # opcional para PKCE público
AUTH_MODE=oauth                # marcar após autenticar com python3 authenticate.py
#
# Método 2: API Key direta (gera cobrança por tokens)
ANTHROPIC_API_KEY=sk-ant-...
# ──────────────────────────────────────────────────────────────────────────────
# ── Seleção de Backend ────────────────────────────────────────────────────────
# BACKEND=claude-code  → usa o Claude Code CLI (assinatura claude.ai, SEM API key)
# BACKEND=api          → usa a API Anthropic direta (exige ANTHROPIC_API_KEY)
# (omitir)             → auto-detect: prefere CLI se disponível
BACKEND=claude-code
# ──────────────────────────────────────────────────────────────────────────────
# ── Fallback Chain ────────────────────────────────────────────────────────────
# Quando FALLBACK_CHAIN_ENABLED=true (padrão), o workspace tenta automaticamente
# backends alternativos quando o primário atinge rate limit:
#   claude-code → codex → api (se configurado)
FALLBACK_CHAIN_ENABLED=true
# Modelo Codex padrão quando BACKEND=codex é usado diretamente
CODEX_MODEL=gpt-5.4-mini
# ──────────────────────────────────────────────────────────────────────────────
DATABASE_URL=sqlite:///memory/workspace.db
OAUTH_DB_URL=sqlite:///memory/oauth_tokens.db
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=workspace
POSTGRES_USER=workspace
POSTGRES_PASSWORD=changeme
REDIS_URL=redis://localhost:6379
GITHUB_TOKEN=ghp_...
DEBUG=false
LOG_LEVEL=INFO
MAX_TOKENS_PER_REQUEST=4096
DAILY_COST_LIMIT_USD=50.0
